# Copy to .env and adjust. Without a .env the app runs on local SQLite.

# SQLite (default, zero setup):
# DATABASE_URL=sqlite:///./journey.db
# Postgres (when docker compose -f ../infra/docker-compose.yml up -d is running):
# DATABASE_URL=postgresql://journey:journey_pass@localhost:5432/journey_db

APP_SECRET=change-me-to-a-long-random-string
TOKEN_EXPIRE_MINUTES=60
DEV_AUTH_ENABLED=true
